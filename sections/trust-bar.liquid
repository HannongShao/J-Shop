<section class="section-shell">
  <div class="page-width">
    <div class="grid grid--3">
      {%- for block in section.blocks -%}
        <article class="card" {{ block.shopify_attributes }}>
          <div class="card__content">
            <p class="badge">
              {% render 'icon', icon: block.settings.icon %}
              <span>{{ block.settings.heading }}</span>
            </p>
            <p class="section-header__text">{{ block.settings.text }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "gift", "label": "Gift" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "globe", "label": "Globe" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free shipping over AU$149"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Use this strip for reassurance, delivery promises, and gifting confidence."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "heading": "Australia shipping",
            "text": "Set clear standard and express delivery expectations."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "gift",
            "heading": "Gift ready options",
            "text": "Highlight gift packaging, note cards, and easy gift selection."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "sparkle",
            "heading": "Material transparency",
            "text": "Use structured product data to explain metal, plating, and gemstone details."
          }
        }
      ]
    }
  ]
}
{% endschema %}

