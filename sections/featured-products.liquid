<section class="section-shell">
  <div class="page-width">
    <div class="section-header">
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <div class="section-header__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    {%- assign featured_collection = section.settings.collection -%}
    {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
      <div class="grid grid--3">
        {%- for product in featured_collection.products limit: section.settings.products_limit -%}
          {% render 'product-card', product_card_product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p>{{ 'sections.featured_products.empty' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Best sellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fastest path to first purchase"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use a featured collection here to surface low-friction hero products, gift-friendly pieces, or your strongest paid traffic landing set.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}

