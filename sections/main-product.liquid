{{ 'product-gallery.js' | asset_url | script_tag }}
{{ 'sticky-atc.js' | asset_url | script_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign form_id = 'ProductForm-' | append: section.id -%}

<section class="section-shell">
  <div class="page-width product">
    <div class="product__gallery" data-product-gallery>
      <div class="product__featured">
        {%- assign featured_media = current_variant.featured_media | default: product.featured_media -%}
        {%- if featured_media.preview_image != blank -%}
          {{
            featured_media.preview_image
            | image_url: width: 1600
            | image_tag:
              widths: '480, 720, 960, 1200, 1600',
              loading: 'eager',
              alt: featured_media.alt | default: product.title,
              data-product-featured-image: true
          }}
        {%- elsif product.featured_image != blank -%}
          {{
            product.featured_image
            | image_url: width: 1600
            | image_tag:
              widths: '480, 720, 960, 1200, 1600',
              loading: 'eager',
              alt: product.title,
              data-product-featured-image: true
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      {%- if product.media.size > 1 -%}
        <div class="product__thumbs">
          {%- for media in product.media -%}
            <button
              class="product__thumb"
              type="button"
              data-product-thumb
              data-image-src="{{ media.preview_image | image_url: width: 1600 }}"
              data-image-srcset="{{ media.preview_image | image_url: width: 480 }} 480w, {{ media.preview_image | image_url: width: 960 }} 960w, {{ media.preview_image | image_url: width: 1600 }} 1600w"
              data-image-alt="{{ media.alt | escape }}"
              aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              {{
                media.preview_image
                | image_url: width: 320
                | image_tag:
                  widths: '120, 180, 240, 320',
                  loading: 'lazy',
                  alt: media.alt | default: product.title
              }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="product__panel">
      {%- if product.vendor != blank and section.settings.show_vendor -%}
        <p class="section-header__eyebrow">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="product__title">{{ product.title }}</h1>

      {%- if product.metafields.custom.short_blurb.value != blank -%}
        <p class="product__subtitle">{{ product.metafields.custom.short_blurb.value }}</p>
      {%- endif -%}

      {% render 'price', price_product: current_variant %}
      {% render 'product-badges', product: product %}

      {% form 'product', product, id: form_id, class: 'product__form', novalidate: 'novalidate' %}
        <div id="{{ form_id }}-anchor" data-product-form-anchor></div>

        {%- if product.variants.size > 1 -%}
          <label class="field">
            <span>{{ 'products.product.variant' | t }}</span>
            <select name="id">
              {%- for variant in product.variants -%}
                <option value="{{ variant.id }}" {% if variant.id == current_variant.id %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }} - {{ variant.price | money }}
                </option>
              {%- endfor -%}
            </select>
          </label>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {%- endif -%}

        <label class="field">
          <span>{{ 'products.product.quantity' | t }}</span>
          <input type="number" name="quantity" min="1" value="1">
        </label>

        <button class="button button--primary" type="submit" {% unless current_variant.available %}disabled{% endunless %}>
          {% if current_variant.available %}
            {{ 'products.product.add_to_cart' | t }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      {% endform %}

      <div class="accordion">
        {%- capture details_content -%}
          <div class="page-copy">
            {{ product.description }}
          </div>
        {%- endcapture -%}
        {% render 'product-accordion-item', title: 'products.product.product_details' | t, content: details_content, open: true %}
        {% render 'product-materials', product: product %}
        {% render 'product-size-guide', product: product %}
        {% render 'product-shipping-note', product: product, section_shipping_copy: section.settings.shipping_copy %}
        {% render 'product-care-note', product: product %}
      </div>
    </div>
  </div>
</section>

<div class="sticky-atc" data-sticky-atc data-sticky-target="{{ form_id }}-anchor">
  <div>
    <strong>{{ product.title }}</strong>
    <div>{% render 'price', price_product: current_variant %}</div>
  </div>
  <a class="button button--primary" href="#{{ form_id }}">{{ 'products.product.sticky_add_to_cart' | t }}</a>
</div>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "textarea",
      "id": "shipping_copy",
      "label": "Default shipping and returns copy",
      "default": "Use this section for clear shipping timing, gift options, and returns information that reduces hesitation."
    }
  ]
}
{% endschema %}

