<section class="section-shell">
  <div class="page-width">
    <div class="section-header">
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.text != blank -%}
        <div class="section-header__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="grid grid--3">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign collection = block.settings.collection -%}
          <article class="card" {{ block.shopify_attributes }}>
            <a href="{{ collection.url }}">
              <div class="product-card__image">
                {%- if collection.featured_image != blank -%}
                  {{
                    collection.featured_image
                    | image_url: width: 900
                    | image_tag:
                      widths: '320, 480, 640, 900',
                      loading: 'lazy',
                      alt: collection.title
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="card__content">
                <h3 class="product-card__title">{{ collection.title }}</h3>
                {%- if block.settings.text != blank -%}
                  <p class="section-header__text">{{ block.settings.text }}</p>
                {%- elsif collection.description != blank -%}
                  <p class="section-header__text">{{ collection.description | strip_html | truncate: 110 }}</p>
                {%- endif -%}
              </div>
            </a>
          </article>
        {%- endfor -%}
      {%- else -%}
        <p>{{ 'sections.featured_collections.empty' | t }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by mood"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections shaped for daily wear and gifting"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Custom text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collections"
    }
  ]
}
{% endschema %}

