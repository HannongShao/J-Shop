{%- assign faq_heading = section.settings.heading -%}
{%- if faq_heading == blank -%}
  {%- assign faq_heading = 'sections.faq.heading' | t -%}
{%- endif -%}

<section class="section-shell">
  <div class="page-width">
    <div class="section-header">
      <h2 class="section-header__title">{{ faq_heading }}</h2>
    </div>
    <div class="accordion">
      {%- for block in section.blocks -%}
        {%- capture faq_content -%}
          <div class="page-copy">{{ block.settings.answer }}</div>
        {%- endcapture -%}
        {% render 'product-accordion-item', title: block.settings.question, content: faq_content, open: block.settings.open %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How should returns and exchanges be explained?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Keep change-of-mind returns separate from statutory consumer rights and make your delivery timing easy to understand.</p>"
        },
        {
          "type": "checkbox",
          "id": "open",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ list",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
