<section class="section-shell">
  <div class="page-width card">
    <div class="card__content">
      <div class="section-header">
        <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="section-header__title">{{ section.settings.heading }}</h2>
        <div class="section-header__text">{{ section.settings.text }}</div>
      </div>
      {%- form 'customer', class: 'grid' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="field">
          <span class="sr-only">{{ 'newsletter.email' | t }}</span>
          <input
            type="email"
            name="contact[email]"
            value="{% if customer %}{{ customer.email }}{% endif %}"
            placeholder="{{ 'newsletter.email' | t }}"
            autocorrect="off"
            autocapitalize="off"
          >
        </label>
        <button class="button button--primary" type="submit">{{ 'newsletter.button_label' | t }}</button>
        {%- if form.posted_successfully? -%}
          <p>{{ 'newsletter.success' | t }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Email retention"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Capture future gifting moments"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Offer product drops, care notes, and seasonal gift edits instead of generic sales language.</p>"
    }
  ],
  "presets": [
    {
      "name": "Newsletter signup"
    }
  ]
}
{% endschema %}

