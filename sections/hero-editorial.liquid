<section class="section-shell">
  <div class="page-width hero">
    <div class="hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="hero__text">{{ section.settings.text }}</div>
      {%- endif -%}
      <div class="hero__actions">
        {% render 'button', button_label: section.settings.primary_label, button_url: section.settings.primary_link, button_style: 'primary', button_icon: 'arrow' %}
        {% render 'button', button_label: section.settings.secondary_label, button_url: section.settings.secondary_link, button_style: 'secondary' %}
      </div>
      {%- if section.settings.note != blank -%}
        <p class="badge">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>

    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag:
            widths: '480, 720, 960, 1200, 1600',
            loading: 'eager',
            alt: section.settings.image.alt | default: section.settings.heading
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero editorial",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Australian-first everyday jewellery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Thoughtfully designed pieces for gifting and daily wear"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Build an editorial first impression with tactile imagery, easy gifting cues, and a calm luxury tone.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop best sellers"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Shop gifts"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Trust note",
      "default": "Ships from Australia"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "Hero editorial"
    }
  ]
}
{% endschema %}

