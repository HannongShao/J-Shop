<section class="section-shell">
  <div class="page-width">
    <div class="section-header">
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="grid grid--3">
      {%- for block in section.blocks -%}
        <blockquote class="card" {{ block.shopify_attributes }}>
          <div class="card__content">
            <p class="section-header__text">{{ block.settings.quote }}</p>
            <cite>{{ block.settings.author }}</cite>
          </div>
        </blockquote>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Review strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Social proof"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build trust with short, high-signal customer quotes"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Use real customer language about gifting, comfort, and quality so the quotes lower hesitation instead of sounding generic."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Customer name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review strip",
      "blocks": [
        { "type": "quote" },
        { "type": "quote" },
        { "type": "quote" }
      ]
    }
  ]
}
{% endschema %}

