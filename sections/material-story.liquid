<section class="section-shell">
  <div class="page-width hero">
    <div class="hero__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            widths: '480, 720, 960, 1200, 1400',
            loading: 'lazy',
            alt: section.settings.heading
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
    <div>
      <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
      <div class="section-header__text">{{ section.settings.text }}</div>
      <div class="grid">
        {%- for block in section.blocks -%}
          <div class="card" {{ block.shopify_attributes }}>
            <div class="card__content">
              <p class="badge">
                {% render 'icon', icon: block.settings.icon %}
                <span>{{ block.settings.heading }}</span>
              </p>
              <p class="section-header__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Material story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Material clarity"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Use this space to explain what customers are buying"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>For a jewellery store, this module should explain metal quality, plating, care, and the difference between everyday pieces and occasion-led styles.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "sparkle",
          "options": [
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "gift", "label": "Gift" },
            { "value": "truck", "label": "Truck" },
            { "value": "globe", "label": "Globe" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Transparent details"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Explain the details customers need to trust the product."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Material story",
      "blocks": [
        { "type": "point" },
        { "type": "point" },
        { "type": "point" }
      ]
    }
  ]
}
{% endschema %}

