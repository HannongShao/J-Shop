{%- case icon -%}
  {%- when 'menu' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M4 7h16M4 12h16M4 17h16"></path>
    </svg>
  {%- when 'close' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M6 6l12 12M18 6L6 18"></path>
    </svg>
  {%- when 'search' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75">
      <circle cx="11" cy="11" r="6"></circle>
      <path d="M20 20l-4.2-4.2"></path>
    </svg>
  {%- when 'cart' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75">
      <circle cx="9" cy="20" r="1.6"></circle>
      <circle cx="17" cy="20" r="1.6"></circle>
      <path d="M3 4h2l2.2 10.5a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.8L20 7H7.2"></path>
    </svg>
  {%- when 'arrow' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M5 12h14M13 5l7 7-7 7"></path>
    </svg>
  {%- when 'chevron' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  {%- when 'mail' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M4 6h16v12H4z"></path>
      <path d="M4 8l8 6 8-6"></path>
    </svg>
  {%- when 'globe' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <circle cx="12" cy="12" r="9"></circle>
      <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"></path>
    </svg>
  {%- when 'gift' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M4 10h16v10H4zM12 10v10M4 14h16"></path>
      <path d="M12 10s-4-1.2-4-4a2 2 0 1 1 4 0m0 4s4-1.2 4-4a2 2 0 1 0-4 0"></path>
    </svg>
  {%- when 'sparkle' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7z"></path>
    </svg>
  {%- when 'truck' -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M3 7h11v8H3zM14 10h4l3 3v2h-7z"></path>
      <circle cx="7.5" cy="18" r="1.5"></circle>
      <circle cx="18.5" cy="18" r="1.5"></circle>
    </svg>
  {%- else -%}
    <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75">
      <circle cx="12" cy="12" r="8"></circle>
    </svg>
{%- endcase -%}

