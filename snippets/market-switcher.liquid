{%- if settings.enable_market_selector and localization.available_countries.size > 1 -%}
  {%- form 'localization', class: 'localization-form' -%}
    <label class="field">
      <span>{{ 'localization.country_label' | t }}</span>
      <select name="country_code" onchange="this.form.submit()">
        {%- for country in localization.available_countries -%}
          <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
            {{ country.name }} ({{ country.currency.iso_code }})
          </option>
        {%- endfor -%}
      </select>
    </label>
  {%- endform -%}
{%- endif -%}

